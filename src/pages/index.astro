---
export const prerender = false;

import Countdown from '../components/invitation/Countdown.astro';
import DressCode from '../components/invitation/DressCode.astro';
import Footer from '../components/invitation/Footer.astro';
import Gallery from '../components/invitation/Gallery.astro';
import Hero from '../components/invitation/Hero.astro';
import Itinerary from '../components/invitation/Itinerary.astro';
import MapSection from '../components/invitation/MapSection.astro';
import MusicPlayer from '../components/invitation/MusicPlayer.astro';
import PlaylistSection from '../components/invitation/PlaylistSection.astro';
import RSVPForm from '../components/invitation/RSVPForm.astro';
import Toast from '../components/Toast.astro';
import { getGuest } from '../lib/guests';
import { getConfirmations } from '../lib/storage';
import '../styles/global.css';

const guestId = Astro.url.searchParams.get('guest') ?? '';
const isGuest = !!Astro.url.searchParams.get('guest');
const [guest, confirmations] = await Promise.all([getGuest(guestId), getConfirmations()]);
const guestConfirmation = confirmations.find((c) => c.guestId === guestId);
const hasTicket = !!guestConfirmation?.attending;

const ogImage = new URL('/og-image.png', Astro.site).href;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Invitación de boda — Carlos Ávila y Cherly Barahona · 18 de Abril 2026" />
    <title>Boda Ávila  Barahona · 18 de Abril 2026</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Great+Vibes&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content="Boda Ávila ♥ Barahona" />
    <meta property="og:description" content="Carlos y Cherly se unen en matrimonio el 18 de Abril de 2026" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
  </head>

  <body>
    <Hero guestName={isGuest ? guest.name : undefined} seats={guest.seats} />
    <Countdown />
    <Itinerary />
    <DressCode seats={guest.seats} />
    <Gallery />
    <MapSection seats={guest.seats} />
    <PlaylistSection guestId={guest.id} seats={guest.seats} locked={!isGuest} />
    <RSVPForm guestId={guest.id} guestName={guest.name} maxSeats={guest.seats} locked={!isGuest} hasTicket={hasTicket} />
    <Footer />
    <MusicPlayer />
    <Toast />
  </body>
</html>
