---
export const prerender = false;

import { getConfirmations, getSuggestions, getGuests } from '../../lib/storage';
import '../../styles/global.css';

const [confirmations, suggestions, guests] = await Promise.all([
  getConfirmations(),
  getSuggestions(),
  getGuests(),
]);

const tab    = Astro.url.searchParams.get('tab')    ?? 'confirmaciones';
const filter = Astro.url.searchParams.get('filter') ?? 'all';

const filtered = confirmations.filter(c => {
  if (filter === 'yes') return c.attending;
  if (filter === 'no') return !c.attending;
  return true;
});

const guestMap      = Object.fromEntries(guests.map(g => [g.id, g.name]));
const totalSeats    = guests.reduce((sum, g) => sum + g.seats, 0);
const confirmed     = confirmations.filter(c => c.attending);
const declined      = confirmations.filter(c => !c.attending);
const confirmedSeats = confirmed.reduce((sum, c) => sum + c.attendees, 0);
const pending       = guests.length - confirmations.length;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin — Boda Ávila ♥ Barahona</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Great+Vibes&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <meta name="robots" content="noindex, nofollow" />
  </head>

  <body class="min-h-screen bg-cream">

    <!-- Navbar -->
    <nav class="
      flex flex-col gap-2 border-b border-[#cdd5eb] bg-white px-4 py-3
      sm:flex-row sm:items-center sm:justify-between sm:px-6
    ">
      <div>
        <p class="font-script text-2xl/tight text-[#c9a86c]">Carlos &amp; Cherly</p>
        <p class="text-[10px] tracking-widest text-brown-muted uppercase">Panel Administrativo</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/" target="_blank" class="
          flex-1 rounded-full border border-[#cdd5eb] px-4 py-2 text-center
          text-xs text-brown-muted transition-colors
          hover:bg-rose-pale
          sm:flex-none
        ">
          Ver invitación
        </a>
        <a href="/api/admin-logout" class="
          flex-1 rounded-full bg-rose-pale px-4 py-2 text-center text-xs
          text-[#c9a86c] transition-colors
          hover:bg-[#cdd5eb]
          sm:flex-none
        ">
          Cerrar sesión
        </a>
      </div>
    </nav>

    <main class="
      mx-auto max-w-6xl px-4 py-8
      sm:px-6
    ">

      <!-- Section tabs -->
      <div class="mb-8 grid grid-cols-3 gap-2">
        <a href="/admin?tab=confirmaciones"
          class={`
            flex flex-col items-center justify-center gap-1 rounded-2xl px-2
            py-2.5 text-center font-medium transition-colors
            sm:flex-row sm:gap-2 sm:px-5
            ${tab === 'confirmaciones' ? `bg-brown-dark text-white` : `
              border border-[#cdd5eb] bg-white text-brown-muted
              hover:bg-rose-pale
            `}
          `}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <span class="
            text-[11px] leading-tight
            sm:text-sm
          ">Confirm. <span id="count-confirmaciones" class="font-semibold">({confirmations.length})</span></span>
        </a>
        <a href="/admin?tab=canciones"
          class={`
            flex flex-col items-center justify-center gap-1 rounded-2xl px-2
            py-2.5 text-center font-medium transition-colors
            sm:flex-row sm:gap-2 sm:px-5
            ${tab === 'canciones' ? `bg-brown-dark text-white` : `
              border border-[#cdd5eb] bg-white text-brown-muted
              hover:bg-rose-pale
            `}
          `}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
          </svg>
          <span class="
            text-[11px] leading-tight
            sm:text-sm
          ">Canciones <span id="count-canciones" class="font-semibold">({suggestions.length})</span></span>
        </a>
        <a href="/admin?tab=invitados"
          class={`
            flex flex-col items-center justify-center gap-1 rounded-2xl px-2
            py-2.5 text-center font-medium transition-colors
            sm:flex-row sm:gap-2 sm:px-5
            ${tab === 'invitados' ? `bg-brown-dark text-white` : `
              border border-[#cdd5eb] bg-white text-brown-muted
              hover:bg-rose-pale
            `}
          `}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
          <span class="
            text-[11px] leading-tight
            sm:text-sm
          ">Invitados <span id="count-invitados" class="font-semibold">({guests.length})</span></span>
        </a>
      </div>

      <!-- ── TAB: CONFIRMACIONES ───────────────────────────── -->
      {tab === 'confirmaciones' && <>
        <div class="
          mb-8 grid grid-cols-2 gap-4
          sm:grid-cols-4
        ">
          {[
            { label: 'Asientos totales', value: totalSeats,      color: '#1a2744' },
            { label: 'Asistirán',        value: confirmedSeats,  color: '#2d7a4f' },
            { label: 'No asistirán',     value: declined.length, color: '#c9a86c' },
            { label: 'Pendientes',       value: pending,         color: '#4d5f8a' },
          ].map(stat => (
            <div class="
              rounded-2xl border border-[#cdd5eb] bg-white p-5 text-center
              shadow-sm
            ">
              <p class="mb-1 font-serif text-4xl font-semibold" style={`color: ${stat.color}`}>{stat.value}</p>
              <p class="text-xs tracking-widest text-brown-muted uppercase">{stat.label}</p>
            </div>
          ))}
        </div>

        <div class="mb-6 flex gap-2 overflow-x-auto pb-1">
          {[
            { label: `Todos (${confirmations.length})`, value: 'all' },
            { label: `Asisten (${confirmed.length})`,   value: 'yes' },
            { label: `No asisten (${declined.length})`, value: 'no'  },
          ].map(t => (
            <a href={`/admin?tab=confirmaciones&filter=${t.value}`}
              class={`
                rounded-full px-4 py-2 text-sm font-medium whitespace-nowrap
                transition-colors
                ${filter === t.value ? `bg-[#c9a86c] text-white` : `
                  border border-[#cdd5eb] bg-white text-brown-muted
                  hover:bg-rose-pale
                `}
              `}>
              {t.label}
            </a>
          ))}
        </div>

        {filtered.length === 0 ? (
          <div class="
            rounded-2xl border border-[#cdd5eb] bg-white p-12 text-center
          ">
            <div class="
              mx-auto mb-4 flex size-16 items-center justify-center rounded-full
              bg-rose-pale
            ">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <p class="font-serif text-xl text-brown-muted">No hay confirmaciones aún</p>
          </div>
        ) : (
          <div class="
            grid gap-4
            sm:grid-cols-2
            lg:grid-cols-3
          ">
            {filtered.map(c => (
              <div class={`
                flex flex-col gap-3 rounded-2xl border bg-white p-5 shadow-sm
                ${c.attending ? `border-green-100` : `border-[#cdd5eb]`}
              `} data-guest-id={c.guestId}>
                <!-- Header: name + badge -->
                <div class="flex items-start justify-between gap-2">
                  <p class="font-serif text-lg/tight text-brown-dark">{c.guestName}</p>
                  {c.attending
                    ? <span class="
                      inline-flex shrink-0 items-center gap-1 rounded-full
                      bg-green-50 px-2.5 py-1 text-xs font-medium text-green-700
                    ">✓ Asiste</span>
                    : <span class="
                      inline-flex shrink-0 items-center gap-1 rounded-full
                      bg-red-50 px-2.5 py-1 text-xs font-medium text-red-500
                    ">✗ No asiste</span>}
                </div>

                <!-- Divider -->
                <div class="h-px bg-rose-pale"></div>

                <!-- Stats row -->
                <div class="flex items-center gap-4 text-sm text-brown-muted">
                  {c.attending && (
                    <div class="flex items-center gap-1.5">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                      </svg>
                      <span>{c.attendees} {c.attendees === 1 ? 'persona' : 'personas'}</span>
                    </div>
                  )}
                  <div class="ml-auto flex items-center gap-1.5">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <span class="text-xs">{new Date(c.confirmedAt).toLocaleDateString('es-HN', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
                  </div>
                </div>

                <!-- Message -->
                {c.message && (
                  <p class="
                    rounded-xl bg-cream px-3 py-2 text-xs/relaxed
                    text-brown-muted italic
                  ">"{c.message}"</p>
                )}

                <!-- Delete -->
                <button
                  class="
                    btn-delete-confirmation rounded-full border border-red-100
                    py-2 text-xs text-red-400 transition-colors
                    hover:bg-red-50
                  "
                  data-id={c.guestId}
                  data-name={c.guestName}
                >
                  Eliminar confirmación
                </button>
              </div>
            ))}
          </div>
        )}
      </>}

      <!-- ── TAB: CANCIONES ───────────────────────────────── -->
      {tab === 'canciones' && (
        <div>
          <div class="mb-6 flex items-center justify-between">
            <h2 class="font-serif text-2xl text-brown-dark">Canciones sugeridas</h2>
            <span class="text-sm text-brown-muted">{suggestions.length} {suggestions.length === 1 ? 'sugerencia' : 'sugerencias'}</span>
          </div>
          {suggestions.length === 0 ? (
            <div class="
              rounded-2xl border border-[#cdd5eb] bg-white p-12 text-center
            ">
              <div class="
                mx-auto mb-4 flex size-16 items-center justify-center
                rounded-full bg-rose-pale
              ">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
                </svg>
              </div>
              <p class="font-serif text-xl text-brown-muted">Aún no hay sugerencias</p>
            </div>
          ) : (
            <div class="
              grid gap-4
              sm:grid-cols-2
              lg:grid-cols-3
            ">
              {suggestions.map((s, i) => (
                <div class="
                  flex flex-col gap-3 rounded-2xl border border-[#cdd5eb]
                  bg-white p-5 shadow-sm
                " data-song-index={i}>
                  <div class="flex items-start gap-4">
                    <div class="
                      flex size-10 shrink-0 items-center justify-center
                      rounded-full bg-rose-pale
                    ">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <p class="truncate font-serif text-base text-brown-dark">{s.song}</p>
                      {s.artist && <p class="truncate text-sm text-brown-muted">{s.artist}</p>}
                      <p class="mt-1.5 text-[11px] text-[#8fa0c0]">{guestMap[s.guestId] ?? 'Invitado general'}</p>
                    </div>
                  </div>
                  <button
                    class="
                      btn-delete-song rounded-full border border-red-100
                      py-2 text-xs text-red-400 transition-colors
                      hover:bg-red-50
                    "
                    data-index={i}
                    data-song={s.song}
                  >
                    Eliminar canción
                  </button>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      <!-- ── TAB: INVITADOS ───────────────────────────────── -->
      {tab === 'invitados' && (
        <div>
          <div class="mb-6 flex items-center justify-between">
            <h2 class="font-serif text-2xl text-brown-dark">Gestión de Invitados</h2>
            <button
              id="btn-add-guest"
              class="
                flex items-center gap-2 rounded-full bg-[#c9a86c] px-5 py-2.5
                text-sm font-medium text-white shadow-sm transition-colors
                hover:bg-[#a8893d]
              "
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Agregar invitado
            </button>
          </div>

          {guests.length === 0 ? (
            <div class="
              rounded-2xl border border-[#cdd5eb] bg-white p-12 text-center
            ">
              <div class="
                mx-auto mb-4 flex size-16 items-center justify-center
                rounded-full bg-rose-pale
              ">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                  <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
                </svg>
              </div>
              <p class="font-serif text-xl text-brown-muted">No hay invitados aún</p>
            </div>
          ) : (
            <div class="
              grid gap-4
              sm:grid-cols-2
              lg:grid-cols-3
            " id="guests-table">
              {guests.map(g => (
                <div
                  class="
                    guest-card flex flex-col gap-3 rounded-2xl border border-[#cdd5eb]
                    bg-white p-5 shadow-sm
                  "
                  data-id={g.id}
                  data-name={g.name}
                  data-seats={g.seats}
                >
                  <!-- Header: name + seats badge -->
                  <div class="flex items-start justify-between gap-2">
                    <p class="
                      guest-name font-serif text-lg/tight text-brown-dark
                    ">{g.name}</p>
                    <span class="
                      guest-seats inline-flex size-8 shrink-0 items-center
                      justify-center rounded-full bg-rose-pale font-serif
                      text-sm font-medium text-[#c9a86c]
                    ">{g.seats}</span>
                  </div>

                  <!-- Divider -->
                  <div class="h-px bg-rose-pale"></div>

                  <!-- Link row -->
                  <div class="flex items-center gap-2">
                    <button
                      class="
                        btn-copy flex grow items-center justify-center gap-1.5
                        rounded-full border border-[#cdd5eb] px-3 py-1.5 text-xs
                        text-[#c9a86c] transition-colors
                        hover:bg-rose-pale
                      "
                      data-id={g.id}
                      data-name={g.name}
                    >
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                      </svg>
                      Copiar
                    </button>
                  </div>

                  <!-- Actions -->
                  <div class="flex items-center gap-2 pt-1">
                    <button
                      class="
                        btn-edit flex-1 rounded-full border border-[#cdd5eb]
                        py-2 text-xs text-brown-muted transition-colors
                        hover:bg-rose-pale
                      "
                      data-id={g.id}
                      data-name={g.name}
                      data-seats={g.seats}
                    >
                      Editar
                    </button>
                    <button
                      class="
                        btn-delete flex-1 rounded-full border border-red-100
                        py-2 text-xs text-red-400 transition-colors
                        hover:bg-red-50
                      "
                      data-id={g.id}
                      data-name={g.name}
                    >
                      Eliminar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </main>

    <!-- ── DRAWER (Add / Edit) ─────────────────────────────── -->
    <div id="drawer-overlay" class="
      fixed inset-0 z-40 hidden bg-black/30 opacity-0 transition-opacity
      duration-200
    "></div>

    <aside id="drawer" class="
      fixed top-0 right-0 z-50 flex size-full translate-x-full flex-col bg-white
      shadow-2xl transition-transform duration-300
      sm:w-96
    ">
      <div class="
        flex items-center justify-between border-b border-[#cdd5eb] px-6 py-5
      ">
        <h3 id="drawer-title" class="font-serif text-xl text-brown-dark">Agregar invitado</h3>
        <button id="drawer-close" class="
          flex size-8 items-center justify-center rounded-full text-brown-muted
          transition-colors
          hover:bg-rose-pale
        ">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <form id="guest-form" class="flex-1 space-y-6 overflow-y-auto p-6">
        <input type="hidden" id="form-id" value="" />

        <div>
          <label class="
            mb-2 block text-xs tracking-widest text-brown-muted uppercase
          " for="form-name">Nombre</label>
          <input
            type="text"
            id="form-name"
            required
            class="
              w-full rounded-xl border border-[#cdd5eb] bg-cream px-4 py-3
              text-brown-dark
              focus:border-transparent focus:ring-2 focus:ring-[#c9a86c]
              focus:outline-none
            "
            placeholder="Familia García"
          />
        </div>

        <div>
          <label class="
            mb-2 block text-xs tracking-widest text-brown-muted uppercase
          " for="form-seats">Asientos</label>
          <input
            type="number"
            id="form-seats"
            min="1"
            max="20"
            value="1"
            required
            class="
              w-full rounded-xl border border-[#cdd5eb] bg-cream px-4 py-3
              text-brown-dark
              focus:border-transparent focus:ring-2 focus:ring-[#c9a86c]
              focus:outline-none
            "
          />
        </div>

        <!-- Generated link preview (only in edit mode) -->
        <div id="link-preview" class="hidden">
          <p class="mb-2 text-xs tracking-widest text-brown-muted uppercase">Enlace de invitación</p>
          <div class="flex items-center gap-2 rounded-xl bg-rose-pale px-4 py-3">
            <p id="link-preview-text" class="
              flex-1 truncate font-mono text-xs text-brown-muted
            "></p>
            <button type="button" id="btn-copy-drawer" class="
              shrink-0 text-[#c9a86c]
              hover:text-[#a8893d]
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
            </button>
          </div>
        </div>

        <p id="form-error" class="hidden text-sm text-red-500"></p>
      </form>

      <div class="border-t border-[#cdd5eb] px-6 py-5">
        <button
          id="form-submit"
          form="guest-form"
          type="submit"
          class="
            w-full rounded-xl bg-[#c9a86c] py-3 font-medium text-white
            transition-colors
            hover:bg-[#a8893d]
          "
        >
          Guardar
        </button>
      </div>
    </aside>

    <!-- ── TOAST ────────────────────────────────────────────── -->
    <div id="toast" class="
      pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2
      rounded-full bg-brown-dark px-5 py-3 text-sm whitespace-nowrap text-white
      opacity-0 shadow-lg transition-opacity duration-200
    "></div>

    <script>
      // ── Drawer ──────────────────────────────────────────────────
      const overlay      = document.getElementById('drawer-overlay')!;
      const drawer       = document.getElementById('drawer')!;
      const drawerTitle  = document.getElementById('drawer-title')!;
      const drawerClose  = document.getElementById('drawer-close')!;
      const formId       = document.getElementById('form-id') as HTMLInputElement;
      const formName     = document.getElementById('form-name') as HTMLInputElement;
      const formSeats    = document.getElementById('form-seats') as HTMLInputElement;
      const formError    = document.getElementById('form-error')!;
      const formSubmit   = document.getElementById('form-submit')!;
      const linkPreview  = document.getElementById('link-preview')!;
      const linkText     = document.getElementById('link-preview-text')!;
      const toast        = document.getElementById('toast')!;

      function openDrawer(mode: 'add' | 'edit', id = '', name = '', seats = 1) {
        drawerTitle.textContent = mode === 'add' ? 'Agregar invitado' : 'Editar invitado';
        formId.value    = id;
        formName.value  = name;
        formSeats.value = String(seats);
        formError.classList.add('hidden');

        if (mode === 'edit' && id) {
          const url = `${window.location.origin}/?guest=${id}`;
          linkText.textContent = url;
          linkPreview.classList.remove('hidden');
        } else {
          linkPreview.classList.add('hidden');
        }

        overlay.classList.remove('hidden');
        requestAnimationFrame(() => {
          overlay.classList.remove('opacity-0');
          drawer.classList.remove('translate-x-full');
        });
        formName.focus();
      }

      function closeDrawer() {
        overlay.classList.add('opacity-0');
        drawer.classList.add('translate-x-full');
        setTimeout(() => overlay.classList.add('hidden'), 200);
      }

      drawerClose.addEventListener('click', closeDrawer);
      overlay.addEventListener('click', closeDrawer);

      document.getElementById('btn-add-guest')?.addEventListener('click', () => openDrawer('add'));

      document.querySelectorAll<HTMLButtonElement>('.btn-edit').forEach(btn => {
        btn.addEventListener('click', () => {
          openDrawer('edit', btn.dataset.id!, btn.dataset.name!, Number(btn.dataset.seats));
        });
      });

      // ── Submit ──────────────────────────────────────────────────
      document.getElementById('guest-form')!.addEventListener('submit', async (e) => {
        e.preventDefault();
        formSubmit.textContent = 'Guardando...';
        (formSubmit as HTMLButtonElement).disabled = true;
        formError.classList.add('hidden');

        const id    = formId.value;
        const name  = formName.value.trim();
        const seats = Number(formSeats.value);
        const isEdit = Boolean(id);

        try {
          const res = await fetch(isEdit ? `/api/guests/${id}` : '/api/guests', {
            method: isEdit ? 'PUT' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, seats }),
          });

          if (!res.ok) {
            const err = await res.json();
            formError.textContent = err.error ?? 'Error al guardar';
            formError.classList.remove('hidden');
          } else {
            closeDrawer();
            showToast(isEdit ? 'Invitado actualizado' : 'Invitado agregado');
            if (!isEdit) updateCount('count-invitados', +1);
            setTimeout(() => window.location.reload(), 800);
          }
        } catch {
          formError.textContent = 'Error de red';
          formError.classList.remove('hidden');
        } finally {
          formSubmit.textContent = 'Guardar';
          (formSubmit as HTMLButtonElement).disabled = false;
        }
      });

      // ── Delete ──────────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach(btn => {
        btn.addEventListener('click', async () => {
          const name = btn.dataset.name!;
          if (!confirm(`¿Eliminar a "${name}"? Esta acción no se puede deshacer.`)) return;

          const id = btn.dataset.id!;
          const res = await fetch(`/api/guests/${id}`, { method: 'DELETE' });
          if (res.ok) {
            updateCount('count-invitados', -1);
            const card = btn.closest('.guest-card') as HTMLElement;
            card.style.transition = 'opacity 0.3s';
            card.style.opacity = '0';
            setTimeout(() => {
              card.remove();
              showToast('Invitado eliminado');
            }, 300);
          }
        });
      });

      // ── Copy link ───────────────────────────────────────────────
      async function copyInviteLink(id: string, name: string) {
        const url = `${window.location.origin}/?guest=${id}`;
        await navigator.clipboard.writeText(url);
        showToast(`Enlace de ${name} copiado`);
      }

      document.querySelectorAll<HTMLButtonElement>('.btn-copy').forEach(btn => {
        btn.addEventListener('click', () => copyInviteLink(btn.dataset.id!, btn.dataset.name!));
      });

      document.getElementById('btn-copy-drawer')?.addEventListener('click', () => {
        const id   = formId.value;
        const name = formName.value;
        if (id) copyInviteLink(id, name);
      });

      // ── Delete confirmation ─────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.btn-delete-confirmation').forEach(btn => {
        btn.addEventListener('click', async () => {
          const name = btn.dataset.name!;
          if (!confirm(`¿Eliminar la confirmación de "${name}"? Esta acción no se puede deshacer.`)) return;

          const guestId = btn.dataset.id!;
          const res = await fetch(`/api/confirmations/${guestId}`, { method: 'DELETE' });
          if (res.ok) {
            updateCount('count-confirmaciones', -1);
            const card = btn.closest('[data-guest-id]') as HTMLElement;
            card.style.transition = 'opacity 0.3s';
            card.style.opacity = '0';
            setTimeout(() => {
              card.remove();
              showToast('Confirmación eliminada');
            }, 300);
          }
        });
      });

      // ── Delete song ─────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.btn-delete-song').forEach(btn => {
        btn.addEventListener('click', async () => {
          const song = btn.dataset.song!;
          if (!confirm(`¿Eliminar la canción "${song}"? Esta acción no se puede deshacer.`)) return;

          const index = btn.dataset.index!;
          const res = await fetch(`/api/songs/${index}`, { method: 'DELETE' });
          if (res.ok) {
            updateCount('count-canciones', -1);
            const card = btn.closest('[data-song-index]') as HTMLElement;
            card.style.transition = 'opacity 0.3s';
            card.style.opacity = '0';
            setTimeout(() => {
              card.remove();
              showToast('Canción eliminada');
            }, 300);
          }
        });
      });

      // ── Tab counters ────────────────────────────────────────────
      function updateCount(id: string, delta: number) {
        const el = document.getElementById(id);
        if (!el) return;
        const current = parseInt(el.textContent?.replace(/\D/g, '') ?? '0');
        el.textContent = `(${Math.max(0, current + delta)})`;
      }

      // ── Toast ───────────────────────────────────────────────────
      let toastTimer: ReturnType<typeof setTimeout>;
      function showToast(msg: string) {
        clearTimeout(toastTimer);
        toast.textContent = msg;
        toast.classList.remove('opacity-0');
        toastTimer = setTimeout(() => toast.classList.add('opacity-0'), 2500);
      }
    </script>

  </body>
</html>
