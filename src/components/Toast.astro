---
---

<div
  id="toast"
  role="status"
  aria-live="polite"
  class="
    pointer-events-none fixed bottom-28 left-1/2 z-70
    w-[min(calc(100vw-2rem),360px)] -translate-x-1/2
    sm:right-6 sm:bottom-8 sm:left-auto sm:translate-x-0
  "
>
  <div
    id="toast-inner"
    class="
      flex translate-y-3 items-start gap-3 rounded-2xl border
      border-[#c9a86c]/30 bg-[#0d1b35] p-4 opacity-0 shadow-2xl transition-all
      duration-300 ease-out
    "
  >
    <!-- Icon -->
    <div id="toast-icon-wrap" class="
      mt-0.5 flex size-9 shrink-0 items-center justify-center rounded-full
      bg-[#c9a86c]/15
    "></div>

    <!-- Text -->
    <div class="min-w-0 flex-1">
      <p id="toast-title" class="font-serif text-[15px] leading-snug text-white"></p>
      <p id="toast-body" class="mt-0.5 text-xs/relaxed text-white/60"></p>
    </div>

    <!-- Close -->
    <button
      id="toast-close"
      aria-label="Cerrar"
      class="
        pointer-events-auto mt-1 shrink-0 text-white/30 transition-colors
        hover:text-white/70
      "
    >
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M1 1l10 10M11 1L1 11"/>
      </svg>
    </button>
  </div>
</div>

<script>
  const toastEl  = document.getElementById('toast')!;
  const inner    = document.getElementById('toast-inner')!;
  const titleEl  = document.getElementById('toast-title')!;
  const bodyEl   = document.getElementById('toast-body')!;
  const iconWrap = document.getElementById('toast-icon-wrap')!;
  const closeBtn = document.getElementById('toast-close')!;

  let timer: ReturnType<typeof setTimeout> | null = null;

  const ICONS: Record<string, string> = {
    celebrate: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5.8 11.3 2 22l10.7-3.79"/><path d="M4 3h.01M22 8h.01M15 2h.01M22 20h.01M22 2l-2.24 2.24"/><path d="m22 13-2.5-2.5"/><path d="m8 8-2.24-2.24"/><path d="m16 15-4.5-4.5"/></svg>`,
    heart:     `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    music:     `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
    hug:       `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="4"/><path d="M6 21v-2a6 6 0 0 1 12 0v2"/></svg>`,
  };

  function show(opts: { title: string; body: string; icon?: string; duration?: number }) {
    if (timer) clearTimeout(timer);

    titleEl.textContent  = opts.title;
    bodyEl.textContent   = opts.body;
    iconWrap.innerHTML   = ICONS[opts.icon ?? 'heart'];

    inner.classList.remove('opacity-0', 'translate-y-3');
    inner.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
    toastEl.classList.add('pointer-events-auto');

    timer = setTimeout(hide, opts.duration ?? 5000);
  }

  function hide() {
    inner.classList.add('opacity-0', 'translate-y-3');
    inner.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
    toastEl.classList.remove('pointer-events-auto');
  }

  closeBtn.addEventListener('click', () => { if (timer) clearTimeout(timer); hide(); });

  (window as any).showToast = show;
</script>
