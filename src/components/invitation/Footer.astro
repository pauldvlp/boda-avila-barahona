---
---

<footer class="
  bg-linear-to-b from-brown-dark to-[#0d1b35] px-6 py-16 text-center
">
  <div class="mx-auto max-w-lg">
    <!-- Ornament -->
    <div class="mx-auto mb-8 flex max-w-xs items-center gap-3">
      <div class="h-px flex-1 bg-[#c9a86c] opacity-40"></div>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="#c9a86c" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 0L12.2 7.8L20 10L12.2 12.2L10 20L7.8 12.2L0 10L7.8 7.8L10 0Z"/>
      </svg>
      <div class="h-px flex-1 bg-[#c9a86c] opacity-40"></div>
    </div>

    <!-- Names -->
    <p class="mb-2 font-script text-5xl text-[#c9a86c] drop-shadow-md">Carlos &amp; Cherly</p>
    <p class="mb-6 font-serif text-lg tracking-widest text-white/80">18 · Abril · 2026</p>

    <!-- Verse -->
    <div class="
      mb-8 rounded-2xl border border-white/10 bg-white/10 px-6 py-5
      backdrop-blur-sm
    ">
      <p class="mb-2 font-serif text-base/relaxed text-white/90 italic">
        "Todo lo hizo hermoso en su tiempo"
      </p>
      <p class="text-xs tracking-widest text-[#c9a86c] uppercase">— Eclesiastés 3:11</p>
    </div>

    <!-- Parents -->
    <div class="mb-8 grid grid-cols-2 gap-6 text-sm">
      <div>
        <p class="mb-2 text-[10px] tracking-widest text-[#c9a86c] uppercase">Padres de la novia</p>
        <p class="font-serif text-white/90">Danilo Barahona</p>
        <p class="font-serif text-white/90">Brenda Aguilar</p>
      </div>
      <div>
        <p class="mb-2 text-[10px] tracking-widest text-[#c9a86c] uppercase">Padres del novio</p>
        <p class="font-serif text-white/90">Carlos Ávila</p>
        <p class="font-serif text-white/90">Yolanda Flores</p>
      </div>
    </div>

    <!-- Bottom ornament -->
    <div class="mx-auto flex max-w-xs items-center gap-3">
      <div class="h-px flex-1 bg-[#c9a86c] opacity-40"></div>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="#c9a86c"><path d="M6 0L7.4 4.6L12 6L7.4 7.4L6 12L4.6 7.4L0 6L4.6 4.6Z"/></svg>
      <div class="h-px flex-1 bg-[#c9a86c] opacity-40"></div>
    </div>
  </div>
</footer>
