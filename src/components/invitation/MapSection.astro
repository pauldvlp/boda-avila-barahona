---
const address = 'Centro de Día INJUPEMP, Km 8 carretera zona sur, Tegucigalpa, Honduras';
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
---

<section id="map-section" class="
  bg-linear-to-br from-[#0d1b35] via-brown-dark to-[#1e2f52] px-6 py-20
">
  <div class="mx-auto max-w-2xl">
    <div class="mb-10 text-center">
      <p class="mb-3 text-xs tracking-[0.3em] text-white/50 uppercase">Ubicación</p>
      <h2 class="mb-4 font-serif text-4xl text-white">¿Cómo llegar?</h2>
      <p class="font-sans leading-relaxed text-white/70">
        Te esperamos en un lugar especial para celebrar juntos
      </p>
    </div>

    <!-- Address card -->
    <div class="
      map-card mb-6 rounded-2xl border border-white/20 bg-white/10 p-6
      backdrop-blur-sm
    ">
      <div class="flex items-start gap-4">
        <div class="
          mt-0.5 flex size-10 shrink-0 items-center justify-center rounded-full
          bg-white/10
        ">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div>
          <p class="mb-1 font-serif text-lg text-white">Centro de Día INJUPEMP</p>
          <p class="text-sm/relaxed text-white/70">
            Kilómetro 8, carretera que conduce a la zona sur<br/>
            Tegucigalpa F.M., Honduras
          </p>
        </div>
      </div>

      <div class="
        mt-4 grid grid-cols-2 gap-4 border-t border-white/10 pt-4 text-sm
      ">
        <div>
          <p class="mb-1 text-[10px] tracking-widest text-white/40 uppercase">Ceremonia</p>
          <p class="font-medium text-white">Área Verde · 4:00 PM</p>
        </div>
        <div>
          <p class="mb-1 text-[10px] tracking-widest text-white/40 uppercase">Recepción</p>
          <p class="font-medium text-white">Salón Multiusos · 6:00 PM</p>
        </div>
      </div>
    </div>

    <!-- Map iframe -->
    <div class="
      map-card mb-6 overflow-hidden rounded-2xl border border-white/20 shadow-xl
    " style="height: 280px;">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3869.12!2d-87.2279!3d14.0456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTTCsDAyJzQ0LjIiTiA4N8KwMTMnNDAuNCJX!5e0!3m2!1ses!2shn!4v1700000000000!5m2!1ses!2shn"
        width="100%"
        height="280"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación INJUPEMP"
      ></iframe>
    </div>

    <!-- CTA button -->
    <div class="text-center">
      <a
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="
          inline-flex items-center gap-2 rounded-full bg-[#c9a86c] px-8 py-3
          font-semibold text-[#0d1b35] shadow-lg transition-colors
          hover:bg-[#d4bb82]
        "
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Abrir en Google Maps
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.map-card', {
    opacity: 0, y: 40, stagger: 0.2, duration: 0.8, ease: 'power3.out',
    scrollTrigger: { trigger: '#map-section', start: 'top 75%' },
  });
</script>
