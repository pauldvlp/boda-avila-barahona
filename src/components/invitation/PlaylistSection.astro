---
interface Props {
  guestId: string;
  seats: number;
  locked?: boolean;
}
const { guestId, seats, locked = false } = Astro.props;
const plural = seats > 1;
---

<section id="playlist-section" class="
  bg-cream px-4 py-12
  sm:px-6 sm:py-20
">
  <div class="mx-auto max-w-lg text-center">
    <p class="mb-3 text-xs tracking-[0.3em] text-brown-muted uppercase">Playlist</p>
    <h2 class="
      mb-3 font-serif text-3xl text-brown-dark
      sm:mb-4 sm:text-4xl
    ">¿Qué canción no puede faltar?</h2>
    <p class="
      mb-7 font-sans leading-relaxed text-brown-muted
      sm:mb-10
    ">
      {plural ? 'Ayúdennos a crear la playlist perfecta para nuestra celebración' : 'Ayúdanos a crear la playlist perfecta para nuestra celebración'}
    </p>

    {locked ? (
      <div class="
        rounded-2xl border border-[#cdd5eb] bg-white p-5 shadow-sm
        sm:p-8
        flex flex-col items-center justify-center gap-4 py-10 text-center
      ">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <p class="font-script text-3xl text-[#c9a86c]">Invitación Personalizada</p>
        <p class="font-serif text-brown-dark">Esta sección es exclusiva<br/>para cada invitado.</p>
        <p class="text-sm/relaxed text-brown-muted">
          Para sugerir una canción,<br/>
          accede con tu enlace personal.<br/>
          Si no lo tienes, contáctanos.
        </p>
      </div>
    ) : (
    <div id="playlist-form-container" class="
      rounded-2xl border border-[#cdd5eb] bg-white p-5 shadow-sm
      sm:p-8
    ">
      <form id="playlist-form" class="space-y-4">
        <input type="hidden" id="pl-guest-id" value={guestId} />

        <div class="playlist-field text-left">
          <label class="
            mb-2 block text-xs tracking-widest text-brown-muted uppercase
          " for="pl-song">
            Canción
          </label>
          <input
            type="text"
            id="pl-song"
            name="song"
            required
            class="
              w-full rounded-xl border border-[#cdd5eb] bg-cream px-4 py-3
              text-brown-dark placeholder-[#8fa0c0]
              focus:border-transparent focus:ring-2 focus:ring-[#c9a86c]
              focus:outline-none
            "
            placeholder="Nombre de la canción"
          />
        </div>

        <div class="playlist-field text-left">
          <label class="
            mb-2 block text-xs tracking-widest text-brown-muted uppercase
          " for="pl-artist">
            Artista
          </label>
          <input
            type="text"
            id="pl-artist"
            name="artist"
            class="
              w-full rounded-xl border border-[#cdd5eb] bg-cream px-4 py-3
              text-brown-dark placeholder-[#8fa0c0]
              focus:border-transparent focus:ring-2 focus:ring-[#c9a86c]
              focus:outline-none
            "
            placeholder="Nombre del artista"
          />
        </div>

        <button
          type="submit"
          id="pl-submit"
          class="
            mt-2 w-full rounded-xl bg-[#c9a86c] py-3 font-medium text-white
            transition-colors
            hover:bg-[#a8893d]
          "
        >
          Sugerir canción
        </button>
      </form>

      <!-- Success state -->
      <div id="pl-success" class="hidden py-6 text-center">
        <div class="
          mx-auto mb-5 flex size-20 items-center justify-center rounded-full
          bg-rose-pale
        ">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18V5l12-2v13"/>
            <circle cx="6" cy="18" r="3"/>
            <circle cx="18" cy="16" r="3"/>
          </svg>
        </div>
        <p class="mb-2 font-script text-4xl text-[#c9a86c]">¡Gracias!</p>
        <p id="pl-success-msg" class="mb-3 font-serif text-xl text-brown-dark"></p>
        <p class="text-sm/relaxed text-brown-muted">
          {plural ? 'Su canción llegará a la playlist de la celebración.' : 'Tu canción llegará a la playlist de la celebración.'}<br/>
          ¡Carlos y Cherly la bailarán con mucho gusto!
        </p>
      </div>

    </div>
    )}
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animate form fields in on scroll
  gsap.from('.playlist-field', {
    opacity: 0,
    y: 20,
    stagger: 0.15,
    duration: 0.7,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#playlist-section',
      start: 'top 75%',
    },
  });

  const form = document.getElementById('playlist-form') as HTMLFormElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    const guestId = (document.getElementById('pl-guest-id') as HTMLInputElement).value;
    const song = (document.getElementById('pl-song') as HTMLInputElement).value;
    const artist = (document.getElementById('pl-artist') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/song-suggestion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ guestId, song, artist }),
      });

      if (res.ok) {
        const successDiv = document.getElementById('pl-success')!;
        const successMsg = document.getElementById('pl-success-msg')!;
        successMsg.textContent = artist ? `"${song}" — ${artist}` : `"${song}"`;

        gsap.to(form, {
          opacity: 0,
          y: -10,
          duration: 0.3,
          onComplete: () => {
            form.classList.add('hidden');
            successDiv.classList.remove('hidden');
            gsap.from(successDiv, { opacity: 0, y: 20, duration: 0.6 });
          },
        });
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Sugerir canción';
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Sugerir canción';
    }
  });


</script>
