---
---

<section id="gifts-section" class="bg-rose-pale px-6 py-20">
  <div class="mx-auto max-w-lg text-center">
    <p class="mb-3 text-xs tracking-[0.3em] text-brown-muted uppercase">Regalos</p>
    <h2 class="mb-6 font-serif text-4xl text-brown-dark">Mesa de Regalos</h2>

    <!-- Gift icon -->
    <div class="gifts-icon mx-auto mb-8 flex size-20 items-center justify-center rounded-full bg-white shadow-md">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#c9a86c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 12 20 22 4 22 4 12"/>
        <rect x="2" y="7" width="20" height="5"/>
        <line x1="12" y1="22" x2="12" y2="7"/>
        <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
        <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
      </svg>
    </div>

    <!-- Message card -->
    <div class="gifts-card rounded-2xl border border-[#cdd5eb] bg-white px-8 py-10 shadow-sm">
      <p class="mb-4 font-script text-3xl text-[#c9a86c]">Con amor</p>
      <p class="font-serif text-lg/relaxed text-brown-dark">
        La sola presencia es el mayor regalo.
      </p>
      <p class="mt-3 font-sans text-sm/relaxed text-brown-muted">
        Sin embargo, si deseas, puedes obsequiarnos algo o también lo puedes hacer en efectivo.
      </p>
      <p class="mt-6 font-script text-2xl text-[#c9a86c]">¡Gracias!</p>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#gifts-section h2, .gifts-icon, .gifts-card', {
    opacity: 0,
    y: 30,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: { trigger: '#gifts-section', start: 'top 75%' },
  });
</script>
